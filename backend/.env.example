# ===== 必填 =====

# SiliconFlow API Key（向量嵌入 bge-m3 + 重排 bge-reranker-v2-m3 + 默认 LLM）
# 注册地址：https://siliconflow.cn
SILICONFLOW_API_KEY=sk-your-siliconflow-key

# JWT 签名密钥（用于用户认证 token 签发和验证）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
# 不设置则服务拒绝启动
JWT_SECRET=your-jwt-secret-hex-64-chars

# ===== 可选 =====

# DeepSeek 官方 API Key（DeepSeek-V3.2 模型）
# 注册地址：https://platform.deepseek.com
DEEPSEEK_API_KEY_2=sk-your-deepseek-key

# MiniMax API Key（MiniMax-M2.5/M2.7 模型）
# 注册地址：https://platform.minimaxi.com
MINIMAX_API_KEY=sk-your-minimax-key

# Tavily API Key（网络搜索，不填则使用 DuckDuckGo 兜底）
# 注册地址：https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-key

# ===== 可选：LangSmith 监控 =====
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_your-langsmith-key
# LANGCHAIN_PROJECT=arknights-rag

# ===== 可选：服务端口 =====
# PORT=8100
