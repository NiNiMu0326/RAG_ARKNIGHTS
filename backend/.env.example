# SiliconFlow API Key (for embedding and reranking)
# Get your API key from https://siliconflow.cn
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# DeepSeek API Key (for LLM chat - faster than SiliconFlow)
# Get your API key from https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Tavily API Key for internet search (optional)
# Get your API key from https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Server Port (optional, defaults to 8888)
PORT=8888